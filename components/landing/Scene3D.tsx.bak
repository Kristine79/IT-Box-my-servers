'use client';

import { Suspense, useRef } from 'react';
import { Canvas, useFrame } from '@react-three/fiber';
import { Environment, Float, MeshTransmissionMaterial, ContactShadows } from '@react-three/drei';
import * as THREE from 'three';

function FloatingBlob({ position, scale = 1, color = '#3b82f6', speed = 1 }: { position: [number, number, number], scale?: number, color?: string, speed?: number }) {
  const meshRef = useRef<THREE.Mesh>(null);
  
  useFrame((state) => {
    if (meshRef.current) {
      meshRef.current.rotation.x = Math.sin(state.clock.elapsedTime * speed * 0.3) * 0.2;
      meshRef.current.rotation.y = Math.cos(state.clock.elapsedTime * speed * 0.2) * 0.3;
      meshRef.current.position.y = position[1] + Math.sin(state.clock.elapsedTime * speed * 0.5) * 0.3;
    }
  });

  return (
    <Float speed={speed} rotationIntensity={0.5} floatIntensity={0.5}>
      <mesh ref={meshRef} position={position} scale={scale}>
        <sphereGeometry args={[1, 64, 64]} />
        <MeshTransmissionMaterial
          color={color}
          transmission={0.95}
          thickness={0.5}
          roughness={0.05}
          ior={1.5}
          chromaticAberration={0.03}
          distortion={0.1}
          distortionScale={0.5}
          temporalDistortion={0.1}
          backside
        />
      </mesh>
    </Float>
  );
}

function Gear({ position, scale = 1, rotationSpeed = 0.5 }: { position: [number, number, number], scale?: number, rotationSpeed?: number }) {
  const meshRef = useRef<THREE.Mesh>(null);
  
  useFrame((state) => {
    if (meshRef.current) {
      meshRef.current.rotation.z = state.clock.elapsedTime * rotationSpeed;
    }
  });

  // Simple gear-like shape using torus + boxes
  return (
    <group position={position} scale={scale}>
      <Float speed={1} rotationIntensity={0.2} floatIntensity={0.3}>
        <mesh ref={meshRef}>
          <torusGeometry args={[1, 0.35, 16, 32]} />
          <MeshTransmissionMaterial
            color="#60a5fa"
            transmission={0.9}
            thickness={0.3}
            roughness={0.1}
            ior={1.7}
            chromaticAberration={0.02}
            backside
          />
        </mesh>
        {/* Gear teeth */}
        {Array.from({ length: 8 }).map((_, i) => (
          <mesh key={i} position={[Math.cos((i * Math.PI) / 4) * 1.3, Math.sin((i * Math.PI) / 4) * 1.3, 0]} rotation={[0, 0, (i * Math.PI) / 4]}>
            <boxGeometry args={[0.2, 0.5, 0.4]} />
            <MeshTransmissionMaterial
              color="#60a5fa"
              transmission={0.85}
              thickness={0.2}
              roughness={0.15}
              ior={1.6}
              backside
            />
          </mesh>
        ))}
      </Float>
    </group>
  );
}

function GlassPanel({ position, rotation = [0, 0, 0], scale = 1 }: { position: [number, number, number], rotation?: [number, number, number], scale?: number }) {
  return (
    <Float speed={0.8} rotationIntensity={0.3} floatIntensity={0.2}>
      <mesh position={position} rotation={rotation} scale={scale}>
        <boxGeometry args={[2, 2.8, 0.1]} />
        <MeshTransmissionMaterial
          color="#e0f2fe"
          transmission={0.98}
          thickness={0.1}
          roughness={0.0}
          ior={1.3}
          chromaticAberration={0.01}
          backside
        />
      </mesh>
    </Float>
  );
}

function Scene() {
  return (
    <>
      <ambientLight intensity={0.5} />
      <directionalLight position={[5, 5, 5]} intensity={1} color="#bfdbfe" />
      <pointLight position={[-5, 3, -5]} intensity={0.5} color="#dbeafe" />
      
      {/* Floating organic shapes */}
      <FloatingBlob position={[-3, 1, -2]} scale={1.5} color="#3b82f6" speed={0.8} />
      <FloatingBlob position={[3.5, -0.5, -1.5]} scale={1.2} color="#60a5fa" speed={1.2} />
      <FloatingBlob position={[-1, 2.5, -3]} scale={0.8} color="#93c5fd" speed={0.6} />
      <FloatingBlob position={[2, 2, -4]} scale={0.6} color="#bfdbfe" speed={1} />
      
      {/* Gear element */}
      <Gear position={[4, 1.5, -2]} scale={0.8} rotationSpeed={0.3} />
      <Gear position={[-4, -1, -3]} scale={0.5} rotationSpeed={-0.4} />
      
      {/* Glass panels */}
      <GlassPanel position={[0, 0, -3]} rotation={[0.1, 0.3, 0]} scale={1.2} />
      <GlassPanel position={[-2.5, -1.5, -4]} rotation={[0.2, -0.2, 0.1]} scale={0.8} />
      
      {/* Contact shadows for grounding */}
      <ContactShadows
        position={[0, -3, 0]}
        opacity={0.4}
        scale={20}
        blur={2}
        far={4}
      />
      
      <Environment preset="city" />
    </>
  );
}

export function Scene3D() {
  return (
    <div className="absolute inset-0 -z-10">
      <Canvas
        camera={{ position: [0, 0, 6], fov: 45 }}
        gl={{ alpha: true, antialias: true }}
        style={{ background: 'transparent' }}
      >
        <Suspense fallback={null}>
          <Scene />
        </Suspense>
      </Canvas>
    </div>
  );
}
